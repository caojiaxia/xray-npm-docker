{
  "log": { "loglevel": "warning" },
  "inbounds": [{
    "port": 10000,
    "protocol": "vless",
    "settings": {
      "clients": [{ "id": "${UUID}", "level": 0 }],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "xhttp",
      "security": "tls",
      "tlsSettings": {
        "minVersion": "1.3",
        "certificates": [{
          "certificateFile": "/etc/letsencrypt/live/npm-1/fullchain.pem",
          "keyFile": "/etc/letsencrypt/live/npm-1/privkey.pem"
        }]
      },
      "xhttpSettings": { "path": "${XPATH}", "mode": "packet-up" }
    }
  }],
  "outbounds": [{ "protocol": "freedom" }]
}
